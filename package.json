{
  "name": "barrio-oportunidades-app",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:full": "prisma generate && next dev",
    "dev:host": "set HOST=0.0.0.0 && set PORT=3000 && next dev",
    "build": "next build",
    "build:simple": "next build",
    "build:vercel": "prisma db push --skip-generate && next build",
    "build:migrate": "prisma migrate deploy && next build",
    "start": "next start",
    "start:host": "set HOST=0.0.0.0 && set PORT=3000 && next start",
    "start:prod": "npm run build && npm run start:host",
    "host": "npm run start:prod",
    "host:dev": "npm run dev:host",
    "host:simple": "ejecucuones poryectos\\host-simple.bat",
    "host:localhost": "ejecucuones poryectos\\start-localhost.bat",
    "test:notifications": "ejecucuones poryectos\\notifications-test.bat",
    "diagnose:notifications": "ejecucuones poryectos\\diagnose-notifications.bat",
    "test:service-worker": "ejecucuones poryectos\\test-service-worker.bat",
    "test:full-suite": "ejecucuones poryectos\\full-test-suite.bat",
    "prestart": "prisma migrate deploy",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:baseline": "prisma migrate resolve --applied",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
