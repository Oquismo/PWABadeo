    "@radix-ui/themes": "^3.3.0",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@vis.gl/react-google-maps": "^1.8.3",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "framer-motion": "^12.40.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
