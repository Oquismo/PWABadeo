# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/noname
/.noname

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# temporary files
temp_*
*.tmp
*.temp

# test files (local testing only)
test-*.js
test-*.ts
test-*.tsx
*-test.js
*-test.ts
*-test.tsx

# backup and old files
*.backup
*.backup.*
*.old
*.bak

# documentation files for problems resolved
PROBLEMA_*.md
SOLUCION_*.md
*_RESUELTO.md
*_FIX.md

# android temp files
android-settings.json

# sql debug files
*.sql
!schema.sql
!seeds.sql
!migrations/**/*.sql

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.env*.local

/noname
