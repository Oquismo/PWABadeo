{
  "buildCommand": "npm run build:vercel",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "NEXTAUTH_URL": "https://pwa-badeo.vercel.app",
    "NEXT_PUBLIC_APP_URL": "https://pwa-badeo.vercel.app",
    "PGCONNECT_TIMEOUT": "10",
    "PGCOMMAND_TIMEOUT": "10"
  },
  "build": {
    "env": {
      "NEXTAUTH_URL": "https://pwa-badeo.vercel.app",
      "NEXT_PUBLIC_APP_URL": "https://pwa-badeo.vercel.app"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
