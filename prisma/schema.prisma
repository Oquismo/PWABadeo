// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  name             String?
  password         String
  role             String            @default("user")
  createdAt        DateTime          @default(now())
  lastSeen         DateTime?         @db.Timestamptz(3)
  school           String? // Escuela del usuario
  age              Int? // Edad del usuario
  arrivalDate      String? // Fecha de llegada
  departureDate    String? // Fecha de salida
  avatarUrl        String? // URL del avatar
  announcements    Announcement[]
  logs             Log[]
  tasks            Task[]
  pushSubscription PushSubscription?
}

model Announcement {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
  createdBy Int?
  user      User?    @relation(fields: [createdBy], references: [id])
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  color       String
  date        String?
  role        String   @default("user") // 'admin' o 'user'
  avatars     Json?    // array de strings
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int?
  user        User?    @relation(fields: [createdBy], references: [id])
  @@index([role])
  @@index([createdAt])
  @@index([createdBy])
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  subscription Json     // Suscripción push del navegador
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
  
  @@index([email])
  @@index([token])
  @@index([expiresAt])
}
