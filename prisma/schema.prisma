// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  firstName        String?
  lastName         String?
  name             String?
  password         String
  role             String            @default("user")
  createdAt        DateTime          @default(now())
  lastSeen         DateTime?         @db.Timestamptz(3)
  schoolId         Int? // ID de la escuela (relación)
  school           School?           @relation(fields: [schoolId], references: [id]) // Relación con escuela
  age              Int? // Edad del usuario
  arrivalDate      String? // Fecha de llegada
  departureDate    String? // Fecha de salida
  avatarUrl        String? // URL del avatar
  // Campos de ubicación del usuario
  country          String?           @default("Italia") // País del usuario
  city             String? // Ciudad del usuario
  town             String? // Pueblo/Municipio del usuario
  announcements    Announcement[]
  logs             Log[]
  tasks            Task[]
  userEvents       UserEvent[]       // Relación con eventos personalizados
  pushSubscription PushSubscription?
  feedbacks        Feedback[]        // Relación con feedbacks
  
  @@index([schoolId])
}

model School {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Nombre de la escuela
  address     String? // Dirección de la escuela
  city        String? // Ciudad
  province    String? // Provincia/Estado
  town        String? // Pueblo/Municipio
  country     String   @default("Italia") // País
  phoneNumber String? // Teléfono de contacto
  email       String? // Email de contacto
  website     String? // Sitio web
  type        String   @default("pública") // "pública", "privada", "concertada"
  level       String   @default("primaria") // "infantil", "primaria", "secundaria", "bachillerato", "fp"
  description String? // Descripción adicional
  isActive    Boolean  @default(true) // Si está activa para registro
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relación con usuarios
  users       User[]
  
  @@index([name])
  @@index([city])
  @@index([type])
  @@index([level])
  @@index([isActive])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
  createdBy Int?
  user      User?    @relation(fields: [createdBy], references: [id])
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  color       String
  date        String?
  role        String   @default("user") // 'admin' o 'user'
  avatars     Json?    // array de strings
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int?
  user        User?    @relation(fields: [createdBy], references: [id])
  isPublic    Boolean  @default(false)
  @@index([role])
  @@index([createdAt])
  @@index([createdBy])
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  subscription Json     // Suscripción push del navegador
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
  
  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model UserEvent {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime
  type      String   @default("personal") // 'personal', 'program', 'holiday'
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isPublic  Boolean  @default(false)
  
  @@index([userId])
  @@index([date])
  @@index([type])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  message   String
  userId    Int?     // Opcional para feedback anónimo
  user      User?    @relation(fields: [userId], references: [id])
  language  String   @default("es") // Idioma en que se envió el feedback
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false) // Para marcar si ha sido leído por admin
  
  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}
